{
  "name": "@alleato/ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Reusable Web Components for Alleato projects",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./themes/base.css": "./dist/themes/_base.css",
    "./themes/default.css": "./dist/themes/default.css",
    "./themes/terminal.css": "./dist/themes/terminal.css",
    "./themes/newspaper-broadsheet.css": "./dist/themes/newspaper-broadsheet.css",
    "./themes/newspaper-tabloid.css": "./dist/themes/newspaper-tabloid.css",
    "./themes/newspaper-gazette.css": "./dist/themes/newspaper-gazette.css",
    "./styles/buttons.css": "./dist/styles/buttons.css",
    "./styles/animations.css": "./dist/styles/animations.css",
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js",
      "require": "./dist/components/*.cjs"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup && npm run copy-css",
    "copy-css": "mkdir -p dist/themes dist/styles && cp src/themes/*.css dist/themes/ && cp src/styles/*.css dist/styles/",
    "dev": "vite",
    "lint": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "web-components",
    "alleato",
    "ui",
    "components"
  ],
  "author": "Alleato LLC",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  }
}
